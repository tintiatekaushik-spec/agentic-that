{
  "name": "agentic-that",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run publishing:css && node scripts/dev-all.mjs",
    "dev:all": "npm run dev",
    "dev:site": "node scripts/copy-telegram-console.mjs && node scripts/dev-next.mjs",
    "services:telegram": "npm --prefix services/messaging/telegram run server",
    "services:telegram:install": "npm --prefix services/messaging/telegram install",
    "services:instagram": "tsx services/scraping/instagram/src/server.ts",
    "services:publishing": "tsx services/publishing/queue-runner/server/index.ts",
    "publishing:companion": "node scripts/run-publishing-companion.mjs",
    "publishing:companion:hidden": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-publishing-companion-hidden.ps1",
    "publishing:companion:once": "npm run services:publishing",
    "publishing:brand-assets": "node scripts/build-publishing-brand-assets.mjs",
    "publishing:extension:validate": "node scripts/validate-publishing-extension.mjs",
    "publishing:extension:open": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/open-publishing-extension.ps1",
    "publishing:extension:package": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-publishing-extension.ps1",
    "publishing:desktop:install": "npm --prefix apps/publishing-companion-desktop install",
    "publishing:desktop:start": "npm --prefix apps/publishing-companion-desktop start",
    "publishing:desktop:make": "npm --prefix apps/publishing-companion-desktop run make",
    "publishing:desktop:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-publishing-companion.ps1",
    "publishing:release:windows": "npm run publishing:brand-assets && npm run publishing:extension:validate && npm run publishing:extension:package && npm run publishing:desktop:make && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/collect-publishing-release-artifacts.ps1",
    "publishing:install-startup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-publishing-startup.ps1",
    "publishing:uninstall-startup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-publishing-startup.ps1",
    "test:publishing": "node --import tsx --test services/publishing/queue-runner/server/publishing-api.test.ts && npm run publishing:extension:validate && node scripts/build-publishing-companion-runtime.mjs",
    "publishing:css": "node services/publishing/queue-runner/scripts/scope-css.mjs",
    "instagram:login": "node services/scraping/instagram/scripts/save-session.mjs",
    "services:install": "npm run services:telegram:install",
    "telegram:console:build": "node scripts/build-telegram-console.mjs",
    "telegram:dashboard": "npm run services:telegram",
    "dev:telegram": "npm run dev",
    "dev:whatsapp": "npm run dev",
    "dev:messaging": "npm run dev",
    "dev:instagram": "npm run dev",
    "build": "npm run publishing:css && node scripts/copy-telegram-console.mjs && node scripts/build-next.mjs",
    "seed": "node scripts/seed.js",
    "preview": "next start -H 127.0.0.1 -p 4173"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.3.0",
    "@netlify/blobs": "^10.7.9",
    "@netlify/functions": "^5.3.0",
    "@sparticuz/chromium": "^149.0.0",
    "big-integer": "^1.6.52",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.1.16",
    "next": "^15.5.19",
    "node-cron": "^4.6.0",
    "playwright-core": "^1.61.1",
    "postgres": "^3.4.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.7.0",
    "telegram": "^2.26.22",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.12",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "concurrently": "^9.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.0",
    "typescript": "5.8.2"
  }
}
