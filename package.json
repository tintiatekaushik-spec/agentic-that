{
  "name": "agentic-that",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-telegram-console.mjs && node scripts/dev-next.mjs",
    "services:telegram": "npm --prefix services/messaging/telegram run server",
    "services:telegram:install": "npm --prefix services/messaging/telegram install",
    "services:instagram": "tsx services/scraping/instagram/src/server.ts",
    "instagram:login": "node services/scraping/instagram/scripts/save-session.mjs",
    "services:install": "npm run services:telegram:install",
    "telegram:dashboard": "npm run services:telegram",
    "dev:telegram": "concurrently -k -n site,telegram -c cyan,green \"npm run dev\" \"npm run telegram:dashboard\"",
    "dev:whatsapp": "npm run dev",
    "dev:messaging": "concurrently -k -n site,telegram -c cyan,green \"npm run dev\" \"npm run telegram:dashboard\"",
    "dev:instagram": "concurrently -k -n site,instagram -c cyan,magenta \"npm run dev\" \"npm run services:instagram\"",
    "build": "node scripts/copy-telegram-console.mjs && next build",
    "preview": "next start -H 127.0.0.1 -p 4173"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.9",
    "@netlify/functions": "^5.3.0",
    "@sparticuz/chromium": "^149.0.0",
    "better-sqlite3": "^12.11.1",
    "big-integer": "^1.6.52",
    "lucide-react": "^0.468.0",
    "next": "^15.5.19",
    "playwright-core": "^1.61.1",
    "postgres": "^3.4.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "telegram": "^2.26.22"
  },
  "overrides": {
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.0",
    "typescript": "5.8.2"
  }
}
