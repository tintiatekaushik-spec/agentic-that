NEXT_PUBLIC_TELEGRAM_DASHBOARD_URL=/console
NEXT_PUBLIC_WHATSAPP_DASHBOARD_URL=/dashboard
TELEGRAM_API_URL=

# Required by the deployed Telegram API. Generate different random values.
SESSION_ENCRYPTION_KEY=
USER_PROVISIONING_KEY=
SESSION_COOKIE_SECURE=true

# Publish Queue Runner. The local companion uses JSON during this phase.
PUBLISH_QUEUE_DATA_PATH=./data/store.json
# Optional on Netlify. Set only to the HTTPS origin of a separately hosted persistent browser runner.
PUBLISH_QUEUE_API_URL=
PUBLISH_QUEUE_SERVICE_PORT=8792
# Comma-separated sites allowed to use the local companion. Include your deployed Netlify origin.
PUBLISH_QUEUE_WEB_ORIGIN=http://127.0.0.1:3000,http://localhost:3000,https://agenticthat.netlify.app
PUBLISH_QUEUE_AUTH_TOKEN_SECRET=
PUBLISH_QUEUE_OPERATIONS_MANAGER_PASSWORD=
PUBLISH_QUEUE_SCHEDULER_TIMEZONE=Asia/Kolkata
PUBLISH_QUEUE_MAX_CONCURRENT_ACCOUNTS=2
# review prevents a possible duplicate after a crash; retry automatically requeues interrupted posts.
PUBLISH_QUEUE_INTERRUPTED_POST_RECOVERY=review
PUBLISH_QUEUE_COMPANION_RESTART_DELAY_MS=5000
# Set this to the public Chrome Web Store listing after approval.
NEXT_PUBLIC_PUBLISHING_EXTENSION_URL=
# Stable GitHub Release link used by the publishing setup screen.
NEXT_PUBLIC_PUBLISHING_COMPANION_DOWNLOAD_URL=https://github.com/tintiatekaushik-spec/agentic-that/releases/latest/download/AgenticThat-Publishing-Companion-Setup.exe

# AgenticThat website accounts. Netlify uses Blobs; local development uses JSON.
PLATFORM_AUTH_DATA_PATH=data/platform-auth.json

WA_PROVIDER=meta
META_API_VERSION=v25.0
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_APP_ID=
META_WEBHOOK_VERIFY_TOKEN=

# WhatsApp application data uses PostgreSQL. Use one connection variable only.
DATABASE_URL=

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
BUSINESS_NAME=AgenticThat
WA_FROM=+910000000000
CURRENCY=INR

WATI_API_URL=
WATI_ACCESS_TOKEN=

# Authenticated Instagram scraper session. Use consecutive chunks with no gaps.
INSTAGRAM_STORAGE_STATE_BASE64_CHUNK_1=
INSTAGRAM_STORAGE_STATE_BASE64_CHUNK_2=
INSTAGRAM_STORAGE_STATE_BASE64_CHUNK_3=
INSTAGRAM_SESSION_EXPIRY_BUFFER_DAYS=7
INSTAGRAM_MAX_SESSION_ATTEMPTS=3
