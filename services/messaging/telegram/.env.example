# Required backend secrets.
SESSION_ENCRYPTION_KEY=
USER_PROVISIONING_KEY=

# Telegram API ID/hash are entered by each user in the dashboard when connecting a number.

# JSON backend datastore.
DATA_DIR=data

# Local HTTP server.
SERVICE_HOST=127.0.0.1
SERVICE_PORT=8787
CORS_ORIGIN=

# Browser session, login challenge, and rate limits.
LOGIN_CHALLENGE_TTL_MINUTES=10
APP_SESSION_TTL_HOURS=24
SESSION_COOKIE_SECURE=false
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
LOGIN_START_RATE_LIMIT_MAX=5
MESSAGE_RATE_LIMIT_MAX=20

# Optional JSON username/password login config.
AUTH_CONFIG_PATH=

# Optional Telegram Bot API worker. Required only when running npm run bot.
TELEGRAM_BOT_TOKEN=
BOT_ANSWERS_PATH=config/bot-answers.json
BOT_POLL_TIMEOUT_SECONDS=25
BOT_FALLBACK_REPLY=
BOT_RESPONDER_URL=
BOT_RESPONDER_TIMEOUT_SECONDS=15
BOT_CLEAR_WEBHOOK_ON_START=true
