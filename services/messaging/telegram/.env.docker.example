# Copy this file to .env.docker and fill the empty values before running Docker Compose.

# Telegram API ID/hash are entered by each user in the dashboard when connecting a number.

# Generate each value with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_ENCRYPTION_KEY=
USER_PROVISIONING_KEY=

# JSON backend datastore. docker-compose.yml sets this to /app/data inside the container.
DATA_DIR=/app/data

# Optional JSON username/password login config.
# The default image includes config/users.json.
AUTH_CONFIG_PATH=

# Browser session, login challenge, and rate limits.
LOGIN_CHALLENGE_TTL_MINUTES=10
APP_SESSION_TTL_HOURS=24
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
LOGIN_START_RATE_LIMIT_MAX=5
MESSAGE_RATE_LIMIT_MAX=20

# Optional Telegram Bot API worker values. Required only if you run the bot command.
TELEGRAM_BOT_TOKEN=
BOT_ANSWERS_PATH=config/bot-answers.json
BOT_POLL_TIMEOUT_SECONDS=25
BOT_FALLBACK_REPLY=
BOT_RESPONDER_URL=
BOT_RESPONDER_TIMEOUT_SECONDS=15
BOT_CLEAR_WEBHOOK_ON_START=true
